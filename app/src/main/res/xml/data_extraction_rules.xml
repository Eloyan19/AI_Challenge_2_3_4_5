<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude chat database — contains potentially sensitive conversation history -->
        <exclude domain="database" path="chat_db" />
        <exclude domain="database" path="chat_db-shm" />
        <exclude domain="database" path="chat_db-wal" />
        <!-- Exclude SharedPreferences that hold internal settings -->
        <exclude domain="sharedpref" path="context_strategy_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="chat_db" />
        <exclude domain="database" path="chat_db-shm" />
        <exclude domain="database" path="chat_db-wal" />
        <exclude domain="sharedpref" path="context_strategy_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
